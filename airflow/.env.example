# ============================================
# Airflow Environment Variables Template
# Copy to .env and update with your values
# ============================================

# Airflow Configuration
AIRFLOW_HOME=./
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=sqlite:///./airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ============================================
# S3 Configuration
# ============================================
COVID_S3_BUCKET=covid-data-bucket
COVID_S3_PREFIX=covid-data
LOCAL_COVID_FILE_DIR=C:\data\covid

# ============================================
# Snowflake Configuration
# ============================================
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=your_snowflake_account
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=COVID_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=TRANSFORMER

# ============================================
# dBT Configuration
# ============================================
DBT_PROJECT_DIR=../
DBT_ENV_SCRIPT=../set_snowflake_env.ps1
DBT_EXECUTABLE=../.dbt-venv/Scripts/dbt.exe
DBT_PROFILES_DIR=~/.dbt

# ============================================
# Email Configuration (for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_MAIL_FROM=airflow@example.com

# ============================================
# Slack Configuration (for notifications)
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Feature Flags
# ============================================
ENABLE_DATA_QUALITY_CHECKS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_DBT_TESTS=true
